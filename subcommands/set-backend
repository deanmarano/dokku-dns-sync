#!/usr/bin/env bash
source "$(dirname "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)")/config"
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x
source "$PLUGIN_CORE_AVAILABLE_PATH/common/functions"
source "$(dirname "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)")/functions"

service-set-backend-cmd() {
  #E set the DNS backend for a service
  #E dokku $PLUGIN_COMMAND_PREFIX:set-backend prod-dns aws
  #E supported backends: aws, cloudflare (planned)
  #A service, service to configure backend for
  #A backend, DNS provider backend (aws, cloudflare)
  declare desc="set DNS backend for $PLUGIN_SERVICE service"
  local cmd="$PLUGIN_COMMAND_PREFIX:set-backend" argv=("$@")
  [[ ${argv[0]} == "$cmd" ]] && shift 1
  declare SERVICE="$1" BACKEND="$2"

  [[ -z "$SERVICE" ]] && dokku_log_fail "Please specify a service name"
  [[ -z "$BACKEND" ]] && dokku_log_fail "Please specify a backend (aws, cloudflare)"
  
  verify_service_name "$SERVICE"
  
  # Validate backend
  case "$BACKEND" in
    aws|cloudflare)
      ;;
    *)
      dokku_log_fail "Invalid backend '$BACKEND'. Supported backends: aws, cloudflare"
      ;;
  esac
  
  local SERVICE_ROOT="$PLUGIN_DATA_ROOT/$SERVICE"
  local BACKEND_FILE="$SERVICE_ROOT/BACKEND"
  
  echo "$BACKEND" > "$BACKEND_FILE"
  
  dokku_log_info2 "Backend set to '$BACKEND' for service: $SERVICE"
  
  if [[ "$BACKEND" == "aws" ]]; then
    dokku_log_info1 "Next step: dokku $PLUGIN_COMMAND_PREFIX:backend-auth $SERVICE"
    dokku_log_info1 "You'll need: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_DEFAULT_REGION"
  elif [[ "$BACKEND" == "cloudflare" ]]; then
    dokku_log_info1 "Next step: dokku $PLUGIN_COMMAND_PREFIX:backend-auth $SERVICE"
    dokku_log_info1 "You'll need: Cloudflare API token"
  fi
}

service-set-backend-cmd "$@"