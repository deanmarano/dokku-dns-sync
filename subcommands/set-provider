#!/usr/bin/env bash
source "$(dirname "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)")/config"
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x
source "$PLUGIN_CORE_AVAILABLE_PATH/common/functions"
source "$(dirname "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)")/functions"

service-set-provider-cmd() {
  #E set the DNS provider globally
  #E dokku $PLUGIN_COMMAND_PREFIX:set-provider aws
  #E supported providers: aws, cloudflare (planned)
  #A provider, DNS provider (aws, cloudflare)
  declare desc="set DNS provider globally for $PLUGIN_SERVICE"
  local cmd="$PLUGIN_COMMAND_PREFIX:set-provider" argv=("$@")
  [[ ${argv[0]} == "$cmd" ]] && shift 1
  declare PROVIDER="$1"

  [[ -z "$PROVIDER" ]] && dokku_log_fail "Please specify a provider (aws, cloudflare)"
  
  # Validate provider
  case "$PROVIDER" in
    aws|cloudflare)
      ;;
    *)
      dokku_log_fail "Invalid provider '$PROVIDER'. Supported providers: aws, cloudflare"
      ;;
  esac
  
  local GLOBAL_CONFIG_ROOT="$PLUGIN_DATA_ROOT"
  local PROVIDER_FILE="$GLOBAL_CONFIG_ROOT/PROVIDER"
  
  # Create config directory if it doesn't exist
  mkdir -p "$GLOBAL_CONFIG_ROOT" || dokku_log_fail "Unable to create DNS config directory"
  
  echo "$PROVIDER" > "$PROVIDER_FILE"
  
  dokku_log_info2 "Provider set to '$PROVIDER' globally"
  
  # Load the provider to check if validation functions exist
  local PROVIDER_SCRIPT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../providers/$PROVIDER"
  if [[ -f "$PROVIDER_SCRIPT" ]]; then
    source "$PROVIDER_SCRIPT"
    
    # Check if credentials already exist and are valid
    local CREDENTIALS_VALID=false
    if declare -f "dns_provider_${PROVIDER}_validate_credentials" >/dev/null; then
      if "dns_provider_${PROVIDER}_validate_credentials" 2>/dev/null; then
        CREDENTIALS_VALID=true
        dokku_log_info2 "✓ Existing credentials found and validated for $PROVIDER provider"
      fi
    fi
    
    if [[ "$CREDENTIALS_VALID" == "false" ]]; then
      if [[ "$PROVIDER" == "aws" ]]; then
        dokku_log_info1 "Next step: dokku $PLUGIN_COMMAND_PREFIX:verify"
        dokku_log_info1 "You'll need: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_DEFAULT_REGION"
      elif [[ "$PROVIDER" == "cloudflare" ]]; then
        dokku_log_info1 "Next step: dokku $PLUGIN_COMMAND_PREFIX:verify"
        dokku_log_info1 "You'll need: Cloudflare API token"
      fi
    fi
  else
    dokku_log_warn "Provider script not found: $PROVIDER_SCRIPT"
  fi
}

service-set-provider-cmd "$@"