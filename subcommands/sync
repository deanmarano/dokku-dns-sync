#!/usr/bin/env bash
source "$(dirname "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)")/config"
set -eo pipefail
[[ $DOKKU_TRACE ]] && set -x
source "$PLUGIN_CORE_AVAILABLE_PATH/common/functions"
source "$(dirname "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)")/functions"

service-sync-cmd() {
  #E synchronize DNS records for all linked apps using the configured backend
  #E dokku $PLUGIN_COMMAND_PREFIX:sync prod-dns
  #E this will discover all domains from linked apps and update DNS records
  #E to point to the current server's IP address using the configured backend
  #A service, service to sync DNS records for
  declare desc="synchronize DNS records for $PLUGIN_SERVICE service"
  local cmd="$PLUGIN_COMMAND_PREFIX:sync" argv=("$@")
  [[ ${argv[0]} == "$cmd" ]] && shift 1
  declare SERVICE="$1"

  [[ -z "$SERVICE" ]] && dokku_log_fail "Please specify a service name"
  verify_service_name "$SERVICE"
  
  dns_sync_service "$SERVICE"
}

service-sync-cmd "$@"